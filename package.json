{
  "name": "@stackborg/ui-kits",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "description": "Tailwind CSS component library — theme-agnostic, extendable, production-ready",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackborg/ui-kits.git"
  },
  "homepage": "https://github.com/stackborg/ui-kits#readme",
  "bugs": {
    "url": "https://github.com/stackborg/ui-kits/issues"
  },
  "keywords": [
    "react",
    "components",
    "ui-kit",
    "tailwindcss",
    "design-system",
    "typescript"
  ],
  "author": "stackborg",
  "main": "./dist/ui-kits.cjs",
  "module": "./dist/ui-kits.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ui-kits.js",
      "require": "./dist/ui-kits.cjs"
    },
    "./theme": "./dist/theme/tokens.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build && mkdir -p dist/theme && cp src/theme/tokens.css dist/theme/tokens.css",
    "build:storybook": "storybook build",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.3",
    "framer-motion": "^12.38.0",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
